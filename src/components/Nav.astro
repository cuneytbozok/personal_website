---
const links = [
  { label: 'About', sec: 'about', ix: '01.' },
  { label: 'Experience', sec: 'experience', ix: '02.' },
  { label: 'Toolbox', sec: 'toolbox', ix: '03.' },
  { label: 'Certifications', sec: 'certifications', ix: '04.' },
  { label: 'Contact', sec: 'contact', ix: '05.' },
];
---

<nav class="nav" id="nav" aria-label="Main navigation">
  <div class="wrap">
    <a href="#hero" class="brand">
      <span class="mark">CB</span>
      <span>Cüneyt Bozok</span>
    </a>
    <div class="nav-links" id="navLinks">
      {links.map((l) => (
        <a href={`#${l.sec}`} data-sec={l.sec}><span class="ix">{l.ix}</span> {l.label}</a>
      ))}
    </div>
    <div class="nav-cta">
      <a href="#contact" class="btn btn-ghost">Let's Connect</a>
      <button class="burger" id="burger" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>
