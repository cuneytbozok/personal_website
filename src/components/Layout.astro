---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from './Nav.astro';
import MobileMenu from './MobileMenu.astro';
import SocialRail from './SocialRail.astro';
import Footer from './Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <a href="#content" class="skip-to-content">Skip to Content</a>

  <div class="bg-field"></div>
  <div class="bg-grid"></div>

  <Nav />
  <MobileMenu />
  <SocialRail />

  <main id="content" tabindex="-1">
    <slot />
  </main>

  <Footer />
</BaseLayout>

<script>
  (function () {
    'use strict';

    /* ---------- experience expand/collapse ---------- */
    function initExperience() {
      document.querySelectorAll('.xp-head').forEach(function (head) {
        var toggle = function () {
          var item = head.closest('.xp-item');
          if (!item) return;
          var willOpen = !item.classList.contains('open');
          item.classList.toggle('open', willOpen);
          head.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        };
        head.addEventListener('click', toggle);
        head.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); }
        });
      });
    }

    /* ---------- orbit connectors: keep the dashed lines attached to each
       node's dot at any viewport size (node chips don't scale with the
       graphic, so the endpoints must be measured, not hard-coded) ---------- */
    function initOrbit() {
      var orbit = document.querySelector('.orbit');
      var svg = orbit && orbit.querySelector('.orbit-dots');
      if (!orbit || !svg) return;
      var paths = svg.querySelectorAll('path');
      // Each node maps to a path and the corner its dot sits on.
      var nodes = [
        ['n1', function (r) { return [r.right, r.bottom]; }],
        ['n2', function (r) { return [r.left, r.bottom]; }],
        ['n3', function (r) { return [r.right, r.top + r.height / 2]; }],
        ['n4', function (r) { return [r.left, r.top + r.height / 2]; }],
        ['n5', function (r) { return [r.right, r.top]; }],
        ['n6', function (r) { return [r.left, r.top]; }],
      ];
      var draw = function () {
        var o = orbit.getBoundingClientRect();
        if (!o.width || !o.height) return;
        nodes.forEach(function (n, i) {
          var el = orbit.querySelector('.orbit-node.' + n[0]);
          if (!el || !paths[i]) return;
          var p = n[1](el.getBoundingClientRect());
          var x = ((p[0] - o.left) / o.width) * 460;
          var y = ((p[1] - o.top) / o.height) * 460;
          paths[i].setAttribute('d', 'M' + x.toFixed(1) + ' ' + y.toFixed(1) + ' L230 230');
        });
      };
      // Redraw on the next frame so measurement happens after layout settles.
      var raf;
      var schedule = function () {
        if (raf) cancelAnimationFrame(raf);
        raf = requestAnimationFrame(draw);
      };
      schedule();
      setTimeout(draw, 250);                 // catch late reflows / font swaps
      window.addEventListener('resize', schedule, { passive: true });
      window.addEventListener('orientationchange', schedule, { passive: true });
      window.addEventListener('load', schedule);
      if (document.fonts && document.fonts.ready) { document.fonts.ready.then(draw); }
    }

    /* ---------- scroll engine: drives nav state, reveals, active link ---------- */
    var scrollSubs = [];
    function onScrollTick() { for (var i = 0; i < scrollSubs.length; i++) scrollSubs[i](); }
    function startScrollEngine() {
      var ticking = false;
      var handler = function () {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(function () { onScrollTick(); ticking = false; });
      };
      window.addEventListener('scroll', handler, { passive: true });
      window.addEventListener('resize', handler, { passive: true });
      window.addEventListener('load', onScrollTick);
      onScrollTick();
    }

    /* ---------- nav scroll state + active section ---------- */
    function initNav() {
      var nav = document.getElementById('nav');
      if (!nav) return;
      var links = Array.prototype.slice.call(document.querySelectorAll('.nav-links a'));
      var sections = links.map(function (a) { return document.getElementById(a.getAttribute('data-sec')); });

      scrollSubs.push(function () {
        nav.classList.toggle('scrolled', window.scrollY > 24);
        var mid = window.scrollY + window.innerHeight * 0.4;
        var activeId = null;
        for (var i = 0; i < sections.length; i++) {
          var s = sections[i];
          if (!s) continue;
          if (mid >= s.offsetTop) activeId = s.id;
        }
        links.forEach(function (a) { a.classList.toggle('active', a.getAttribute('data-sec') === activeId); });
      });
    }

    /* ---------- mobile menu ---------- */
    function initMobile() {
      var burger = document.getElementById('burger');
      var menu = document.getElementById('mobileMenu');
      if (!burger || !menu) return;
      var setOpen = function (open) {
        burger.classList.toggle('open', open);
        menu.classList.toggle('open', open);
        burger.setAttribute('aria-expanded', open ? 'true' : 'false');
        document.body.style.overflow = open ? 'hidden' : '';
      };
      burger.addEventListener('click', function () { setOpen(!menu.classList.contains('open')); });
      menu.querySelectorAll('a').forEach(function (a) { a.addEventListener('click', function () { setOpen(false); }); });
    }

    /* ---------- scroll reveal (rect-based, IO-independent) ---------- */
    function inViewport(el, margin) {
      var r = el.getBoundingClientRect();
      var vh = window.innerHeight || document.documentElement.clientHeight;
      return r.top < vh - (margin || 0) && r.bottom > 0;
    }
    function initReveal() {
      var els = Array.prototype.slice.call(document.querySelectorAll('.reveal'));
      var armed = document.documentElement.classList.contains('anim');
      var reveal = function (el) {
        el.classList.add('in');
        if (!armed) return;
        // Failsafe: if the transition never completes, force the final state.
        setTimeout(function () {
          if (parseFloat(getComputedStyle(el).opacity) < 0.9) {
            el.style.transition = 'none';
            el.style.opacity = '1';
            el.style.transform = 'none';
          }
        }, 900);
      };
      scrollSubs.push(function () {
        for (var i = els.length - 1; i >= 0; i--) {
          if (inViewport(els[i], 40)) { reveal(els[i]); els.splice(i, 1); }
        }
      });
    }

    /* ---------- count-up stats (rect-based trigger) ---------- */
    function initCounters() {
      var nums = Array.prototype.slice.call(document.querySelectorAll('[data-count]'));
      if (!nums.length) return;
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var run = function (el) {
        var target = parseInt(el.getAttribute('data-count'), 10) || 0;
        var suffix = el.getAttribute('data-suffix') || '';
        if (reduce) { el.textContent = target + suffix; return; }
        var dur = 1400, start = null, done = false;
        var step = function (ts) {
          if (start === null) start = ts;
          var p = Math.min((ts - start) / dur, 1);
          var eased = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.round(eased * target) + suffix;
          if (p < 1) requestAnimationFrame(step); else done = true;
        };
        requestAnimationFrame(step);
        setTimeout(function () { if (!done) el.textContent = target + suffix; }, 1600);
      };
      scrollSubs.push(function () {
        for (var i = nums.length - 1; i >= 0; i--) {
          if (inViewport(nums[i], 60)) { run(nums[i]); nums.splice(i, 1); }
        }
      });
    }

    function init() {
      initOrbit();
      initExperience();
      initNav();
      initMobile();
      initReveal();
      initCounters();
      startScrollEngine();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else { init(); }
  })();
</script>
