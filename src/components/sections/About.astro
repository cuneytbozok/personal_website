---
const stats = [
  {
    tone: 'violet',
    count: 8,
    suffix: '+',
    label: 'Years Experience',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6"/></svg>',
  },
  {
    tone: 'teal',
    count: 50,
    suffix: '+',
    label: 'Projects Delivered',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>',
  },
  {
    tone: 'amber',
    count: 20,
    suffix: '+',
    label: 'Integrations & APIs',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 7V5a2 2 0 0 1 2-2h2"/><path d="M16 3h2a2 2 0 0 1 2 2v2"/><path d="M20 17v2a2 2 0 0 1-2 2h-2"/><path d="M8 21H6a2 2 0 0 1-2-2v-2"/><circle cx="12" cy="12" r="3"/><path d="m15 9 3-3M9 15l-3 3"/></svg>',
  },
  {
    tone: 'rose',
    count: 100,
    suffix: '%',
    label: 'Client Satisfaction',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 1 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/></svg>',
  },
];
---

<section class="section" id="about">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="num">01.</span>
      <h2>About Me</h2>
      <span class="rule"></span>
    </div>
    <div class="about-grid">
      <div class="card about-lead reveal">
        <div class="heading">
          <span class="ic">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 21V8l9-5 9 5v13"/><path d="M9 21v-6h6v6"/><path d="M3 12h18"/></svg>
          </span>
          <h3>Strategy. Architecture. Impact.</h3>
        </div>
        <p>I help enterprises modernize operations by leading discovery, defining target-state architecture, and making fit-to-standard decisions that balance out-of-the-box capabilities with purposeful customization across ITSM/CSM, ITOM, CMDB/CSDM, Virtual Agent, API integrations and more.</p>
        <p>I lead end-to-end engagements from maturity assessment and phased roadmap definition through architecture design, integration patterns, and rollout. I produce durable foundations — architecture blueprints, HLDs/LLDs, ADRs, and API contracts — so delivery teams and stakeholders stay aligned.</p>
        <p>Beyond delivery, I conduct internal ServiceNow trainings, facilitate architecture workshops with integrators and vendors, and participate in senior-level technical interviews to raise hiring quality and delivery standards.</p>
      </div>
      <div class="stats">
        {stats.map((s, i) => (
          <div class={`card stat ${s.tone} reveal`} data-d={i + 1}>
            <span class="ic" set:html={s.icon} />
            <span class="val" data-count={s.count} data-suffix={s.suffix}>0</span>
            <span class="lbl">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
