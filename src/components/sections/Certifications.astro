---
import { certMain, certMicro } from '../../data/portfolio';
---

<section class="section" id="certifications">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="num">04.</span>
      <h2>Certifications</h2>
      <span class="rule"></span>
    </div>
    <div class="cert-wrap">
      <div class="cert-col reveal" data-d="1">
        <h3>ServiceNow Certifications</h3>
        <ul>
          {certMain.map((c) => (
            <li>
              <svg class="ck" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20 6 9 17l-5-5"/></svg>
              <span>{c}</span>
            </li>
          ))}
        </ul>
        <a href="https://www.linkedin.com/in/cuneytbozok/" target="_blank" rel="noopener" class="btn btn-ghost">View all Certifications
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
      <div class="cert-col reveal" data-d="2">
        <h3>ServiceNow Micro-Certifications</h3>
        <ul>
          {certMicro.map((c) => (
            <li>
              <svg class="ck" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20 6 9 17l-5-5"/></svg>
              <span>{c}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="hexbadge reveal" data-d="3">
        <div class="hex">
          <svg class="cert-medal" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="32" cy="25" r="15"/>
            <path d="M32 18.5l2.6 5.3 5.9.9-4.3 4.1 1 5.8L32 38l-5.2 2.6 1-5.8-4.3-4.1 5.9-.9z" fill="currentColor" fill-opacity="0.18"/>
            <path d="M24 38l-4 14 12-6 12 6-4-14"/>
          </svg>
        </div>
        <div class="ring"></div>
      </div>
    </div>
  </div>
</section>
