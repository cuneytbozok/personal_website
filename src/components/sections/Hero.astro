---
const chips = ['CSA', 'CIS-ITSM', 'CAD', 'ITIL', 'CMDB / CSDM', 'AI ENABLEMENT'];
---

<section class="hero" id="hero">
  <div class="wrap">
    <div class="hero-copy">
      <p class="eyebrow reveal">ServiceNow Solution Architect</p>
      <h1 class="reveal" data-d="1">I design. I architect.<span class="l2">I enable.</span></h1>
      <p class="lede reveal" data-d="2">8+ years delivering ITSM, CSM, ITOM, CMDB/CSDM alignment, Virtual Agent experiences, API integrations and more — from discovery and fit-to-standard decisions through architecture design and rollout.</p>
      <div class="cert-chips reveal" data-d="3">
        {chips.map((c) => <span class="chip">{c}</span>)}
      </div>
      <div class="hero-cta reveal" data-d="4">
        <a href="#contact" class="btn btn-primary">Let's Work Together
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href="#experience" class="btn btn-ghost">View My Work
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7M7 7h10v10"/></svg>
        </a>
      </div>
    </div>

    <!-- Orbit graphic -->
    <div class="orbit reveal" data-d="2" aria-hidden="true">
      <svg class="orbit-dots" viewBox="0 0 460 460" fill="none" stroke="var(--accent-line)" stroke-width="1" stroke-dasharray="3 5">
        <path d="M139 75 L230 230" />
        <path d="M330 63 L230 230" />
        <path d="M112 220 L230 230" />
        <path d="M348 210 L230 230" />
        <path d="M148 381 L230 230" />
        <path d="M321 388 L230 230" />
      </svg>
      <div class="orbit-core">
        <div class="layer l4"></div>
        <div class="layer l3"></div>
        <div class="layer l2"></div>
        <div class="layer l1"></div>
        <div class="core-mark">now</div>
      </div>
      <span class="orbit-node n1">Architecture &amp; Design</span>
      <span class="orbit-node n2">AI &amp; Automation Enablement</span>
      <span class="orbit-node n3">Discovery &amp; Assessment</span>
      <span class="orbit-node n4">Integration &amp; APIs</span>
      <span class="orbit-node n5">Delivery &amp; Adoption</span>
      <span class="orbit-node n6">Operate &amp; Optimize</span>
    </div>
  </div>
</section>
